PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# ─── Supabase (Backend) ───────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ─── Base Sepolia RPC ─────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
CHAIN_ID=84532

# ─── Hot-wallet (QR signing) — KEEP SECRET ───────────────────
SIGNER_PRIVATE_KEY=your_signer_private_key_here

# ─── Deployed contract addresses ─────────────────────────────
FEST_PAY_ADDRESS=your_festpay_contract_address_here
FEST_PASS_ADDRESS=your_festpass_contract_address_here
FEST_TOKEN_ADDRESS=your_fest_token_address_here
